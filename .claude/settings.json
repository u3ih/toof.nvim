{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "if": "Bash(git push*)",
            "command": "bash .claude/hooks/check-secrets.sh",
            "timeout": 15,
            "statusMessage": "Scanning for secrets before push..."
          }
        ]
      }
    ]
  }
}
